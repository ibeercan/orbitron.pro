# ============================================================
# Orbitron Backend - Environment Configuration
# ============================================================
# Copy this file to .env and configure your values

# Database
# For production (Docker): postgresql://user:pass@postgres:5432/astrology
# For local dev: sqlite:///./dev.db
DATABASE_URL=sqlite:///./dev.db

# JWT Authentication
# IMPORTANT: Generate a secure key for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers - JSON array with one or more providers
# Each provider needs: name, api_key, base_url, models
# Example:
#   AI_PROVIDERS=[{"name":"openrouter","api_key":"sk-or-...","base_url":"https://openrouter.ai/api/v1","models":["openai/gpt-4.1-nano","anthropic/claude-3.5-sonnet"],"enabled":true}]
# Multiple providers for fallback:
#   AI_PROVIDERS=[{"name":"openrouter","api_key":"key1","base_url":"https://openrouter.ai/api/v1","models":["openai/gpt-4.1-nano"],"enabled":true},{"name":"timeweb","api_key":"key2","base_url":"https://api.timeweb.cloud/v1","models":["openai/gpt-4.1-nano"],"enabled":true}]
AI_PROVIDERS=[]

# AI System Prompt - path to custom prompt file (leave empty for built-in default)
AI_SYSTEM_PROMPT_FILE=

# AI Retry Configuration
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_MIN_WAIT=1
AI_RETRY_MAX_WAIT=10

# AI Token Tracking (cost per 1M tokens in RUB)
AI_TOKEN_TRACKING_ENABLED=true
AI_COST_PER_1M_INPUT_RUB=300.0
AI_COST_PER_1M_OUTPUT_RUB=600.0

# AI Caching (Redis-based)
AI_CACHE_ENABLED=false
AI_CACHE_TTL_SECONDS=21600

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379

# Security
# Allowed CORS origins (JSON array or comma-separated)
ALLOWED_ORIGINS=https://orbitron.pro,http://localhost,http://localhost:5173

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Subscription Limits
FREE_AI_REQUESTS_PER_MONTH=5

# Logging
LOG_LEVEL=DEBUG

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Orbitron <noreply@orbitron.pro>
FRONTEND_URL=http://localhost:5173