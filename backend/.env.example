# ============================================================
# Orbitron Backend — Local Development Configuration
# ============================================================
# Copy this file to .env and configure your values

# Environment
ENVIRONMENT=development

# Database (SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# JWT Authentication
# Generate a key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-insecure-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers — JSON array with one or more providers
# Example: [{"name":"openrouter","api_key":"sk-or-...","base_url":"https://openrouter.ai/api/v1","models":["openai/gpt-4.1-nano"],"enabled":true}]
AI_PROVIDERS=[]

# AI System Prompt — path to custom prompt file (leave empty for default)
AI_SYSTEM_PROMPT_FILE=

# AI Retry
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_MIN_WAIT=1
AI_RETRY_MAX_WAIT=10

# AI Token Tracking (cost per 1M tokens in RUB)
AI_TOKEN_TRACKING_ENABLED=true
AI_COST_PER_1M_INPUT_RUB=300.0
AI_COST_PER_1M_OUTPUT_RUB=600.0

# AI Cache (Redis — disabled by default for dev)
AI_CACHE_ENABLED=false
AI_CACHE_TTL_SECONDS=21600

# Redis (optional for local dev)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP — leave empty to skip sending in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Orbitron <noreply@orbitron.pro>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Security — CORS origins for local dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Subscription Limits
FREE_AI_REQUESTS_PER_MONTH=3
FREE_CHARTS_LIMIT=1

# Migrations
RUN_MIGRATIONS=false

# Logging
LOG_LEVEL=DEBUG