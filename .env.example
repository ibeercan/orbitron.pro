# ============================================================
# Orbitron — Example Configuration
# ============================================================
# Copy this file to .env and fill in the values

# Environment: development | production
ENVIRONMENT=production

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:your-secure-password@postgres:5432/astrology
POSTGRES_DB=astrology
POSTGRES_USER=user
POSTGRES_PASSWORD=your-secure-password

# JWT — MUST be a strong random string in production!
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-strong-random-secret-key-here

# AI Providers — JSON array
# Example: [{"name":"OpenAI","api_key":"sk-...","base_url":"https://api.openai.com/v1","models":["gpt-4.1-nano"],"enabled":true}]
AI_PROVIDERS=[]

# AI System Prompt — path to custom prompt file (leave empty for default)
AI_SYSTEM_PROMPT_FILE=

# AI Retry
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_MIN_WAIT=1
AI_RETRY_MAX_WAIT=10

# AI Token Tracking (cost per 1M tokens in RUB)
AI_TOKEN_TRACKING_ENABLED=true
AI_COST_PER_1M_INPUT_RUB=300.0
AI_COST_PER_1M_OUTPUT_RUB=600.0

# AI Cache (Redis)
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=21600

# Redis
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Orbitron <noreply@orbitron.pro>

# Frontend URL (for email links)
FRONTEND_URL=https://orbitron.pro

# Cookies
COOKIE_DOMAIN=orbitron.pro
COOKIE_SECURE=true

# Security — production CORS origins (comma-separated)
ALLOWED_ORIGINS=https://orbitron.pro,https://api.orbitron.pro

# Subscription Limits
FREE_AI_REQUESTS_PER_MONTH=3
FREE_CHARTS_LIMIT=1

# Migrations — run on startup
RUN_MIGRATIONS=true

# Logging
LOG_LEVEL=INFO